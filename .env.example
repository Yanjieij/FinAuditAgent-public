# =====================================================================
# FinAuditAgent 环境变量模板
# 使用：cp .env.example .env 然后填值
# =====================================================================

# --------- LLM 供应商（OpenAI 兼容，通过 base_url 切换） -----------
# 官方 OpenAI / DeepSeek / 通义 / 自建 vLLM / Claude(via proxy) 都可
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
# 示例：DeepSeek
# OPENAI_BASE_URL=https://api.deepseek.com
# 示例：通义千问
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认模型名（config.py 读取）
# 推理强度高的任务
FIN_LLM_MODEL_REASONING=gpt-4o
# embed / classify 等轻任务（成本路由）
FIN_LLM_MODEL_LIGHT=gpt-4o-mini

# --------- Langfuse（可观测，可选） ---------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --------- 数据库（可选；不填则用 SQLite 文件） ---------
FIN_DB_URL=sqlite:///./.fin_audit.db
# 生产示例：
# FIN_DB_URL=postgresql+psycopg://user:pwd@localhost:5432/fin_audit

# --------- HITL 审批签名密钥 ---------
FIN_HITL_HMAC_SECRET=replace-me-with-32bytes-random

# --------- 审计日志 HMAC 密钥 ---------
FIN_AUDIT_HMAC_SECRET=replace-me-too

# --------- e2b（生产沙箱，可选） ---------
E2B_API_KEY=

# --------- 沙箱资源限额 ---------
FIN_SANDBOX_TIMEOUT_SEC=10
FIN_SANDBOX_MEM_MB=512

# --------- 成本预算 ---------
FIN_MAX_TOKENS_PER_REQUEST=100000
FIN_MAX_USD_PER_REQUEST=0.50
